# Resend API Key (Email sending service)
# Get your API key from https://resend.com/api-keys
# Free tier: 3000 emails/month
RESEND_API_KEY=

# Sender email address (must be verified in Resend)
# For development: use onboard@resend.dev (pre-verified)
# For production: verify your own domain in Resend dashboard
RESEND_FROM_EMAIL=onboard@resend.dev

# Recipient email for contact form notifications (optional)
CONTACT_NOTIFICATION_EMAIL=

# ── Cloudflare R2 Dual-Bucket Configuration ─────────────────────────────────
# From Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create API Token
# (Select "Object Read & Write" for both buckets)

# Cloudflare Account ID (32-char hex): https://dash.cloudflare.com/ → Account Home
CLOUDFLARE_ACCOUNT_ID=

# R2 Bucket names (as created in Cloudflare R2 dashboard)
R2_PREVIEW_BUCKET=sendafun-preview
R2_ORIGINALS_BUCKET=sendafun-originals

# R2 S3-compatible API credentials (R2 API Token)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# R2 Preview Bucket public CDN (r2.dev subdomain or Custom Domain)
#   From bucket → Settings → Public access → r2.dev subdomain URL
#   Example: https://pub-abc123def456.r2.dev  (without trailing slash)
R2_PUBLIC_URL=

# Local path where original high-resolution source images are stored
# (Used only by upload-to-r2.py --originals flag)
R2_ORIGINALS_LOCAL_DIR=
