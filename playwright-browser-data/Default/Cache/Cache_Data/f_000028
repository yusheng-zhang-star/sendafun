function renderCompareTable(planKeys, planLabels) {
  const thead = h("thead", {}, h("tr", {}, [
    h("th", {}, "Feature"),
    ...planLabels.map(l => h("th", {}, l))
  ]));
  const tbody = h("tbody", {}, COMPARE_FEATURES.map(feat => {
    return h("tr", {}, [
      h("td", {}, feat.label),
      ...planKeys.map(pk => {
        const val = (PLAN_FEATURE_MATRIX[pk] || {})[feat.key];
        if (feat.type === "text") {
          return h("td", {}, val === false ? h("span", { class: "feat-nomark" }, "—") : String(val));
        }
        if (val === true) return h("td", {}, h("span", { class: "feat-mark" }, "✅"));
        if (val === false) return h("td", {}, h("span", { class: "feat-nomark" }, "⛔"));
        return h("td", {}, h("span", { class: "feat-nomark" }, "—"));
      })
    ]);
  }));
  return h("table", {}, [thead, tbody]);
}

