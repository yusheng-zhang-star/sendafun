}
function layeredBackground(imageUrl, cat) {
  const grad = getCategoryGradient(cat);
  const safeUrl = typeof imageUrl === "string" && imageUrl ? imageUrl : "";
  if (safeUrl) {
    const quoted = '"' + safeUrl.replace(/(["\\])/g, '\\$1') + '"';
    return {
