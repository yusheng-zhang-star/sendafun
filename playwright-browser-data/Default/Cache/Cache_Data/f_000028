function renderFilterBar(recipient, occasion, tone, query) {
  const chips = [];
  if (recipient) {
    const opt = RECIPIENT_OPTIONS.find(o => o.slug === recipient);
    if (opt) chips.push(renderFilterChip("filterRecipient", "Recipient: " + opt.label, recipient, "recipient"));
  }
  if (occasion) {
    const label = CATEGORY_LABELS[occasion] || occasion;
    chips.push(renderFilterChip("filterOccasion", "Occasion: " + label, occasion, "cat"));
  }
  if (tone) {
    const opt = TONE_OPTIONS.find(o => o.slug === tone);
    if (opt) chips.push(renderFilterChip("filterTone", "Tone: " + opt.label, tone, "tone"));
  }
  const row = [h("div", { style: { display: "flex", gap: "0.5rem", flexWrap: "wrap", alignItems: "center" } }, chips)];
